{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agicore Studio",
  "version": "0.1.0",
  "identifier": "com.agicore.studio",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5182",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Agicore Studio",
        "width": 1600,
        "height": 1000,
        "decorations": false,
        "center": true,
        "minWidth": 1100,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Visual authoring for the Agicore DSL.",
    "longDescription": "Agicore Studio is a focused IDE for building, running, and deploying Agicore systems. Canvas-based authoring for WORKFLOW / PIPELINE / ROUTER declarations with first-class Human QC checkpoints. The .agi source writes itself as you author on the canvas.",
    "copyright": "MIT — see LICENSE at the repo root.",
    "publisher": "Agicore",
    "homepage": "https://github.com/Binary-Blender/agicore",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": ["en-US"]
      },
      "nsis": {
        "installMode": "perMachine",
        "installerIcon": "icons/icon.ico"
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
