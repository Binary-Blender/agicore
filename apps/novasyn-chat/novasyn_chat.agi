// novasyn_chat.agi
// NovaSyn Chat 2.0 — AI-Native Semantic Operating Environment
// The daily driver, rebuilt on the Agicore framework
//
// This is the ultimate proof of the DSL: a real production app
// expressed entirely in 31 declaration types across 7 layers
//
// What was: 9 migrations, 60+ IPC channels, 13 services, 36 source files
// What is now: one .agi file → complete Tauri application

APP novasyn_chat {
  TITLE   "NovaSyn Chat"
  WINDOW  1400x900 frameless
  DB      novasyn_chat.db
  PORT    5173
  THEME   dark
  CURRENT Session
}

// ===================================================================
// AI SERVICE — Multi-provider with streaming
// ===================================================================

AI_SERVICE {
  PROVIDERS   anthropic, openai, google, xai, babyai
  KEYS_FILE   "%APPDATA%/NovaSyn/api-keys.json"
  DEFAULT     anthropic
  STREAMING   true
  MODELS {
    anthropic  "claude-sonnet-4-20250514"        LABEL "Claude Sonnet 4"   DEFAULT
    anthropic  "claude-haiku-4-5-20251001"       LABEL "Claude Haiku 4.5"
    openai     "gpt-4o"                          LABEL "GPT-4o"            DEFAULT
    openai     "gpt-4o-mini"                     LABEL "GPT-4o Mini"
    google     "gemini-2.5-flash-preview-05-20"  LABEL "Gemini 2.5 Flash"  DEFAULT
    xai        "grok-3-latest"                   LABEL "Grok 3"            DEFAULT
  }
}

// ===================================================================
// INTELLIGENT ROUTING — BabyAI Integration
// ===================================================================

ROUTER BabyAI {
  DESCRIPTION "Cooperative intelligence router — gets smarter with every interaction"

  TIER 1 free {
    qwen3_8b: huggingface "Qwen/Qwen3-8B" {
      STRENGTHS   general, math, coding
      CONTEXT     32768
      DEFAULT
    }
    llama_8b: huggingface "meta-llama/Llama-3.1-8B-Instruct" {
      STRENGTHS   general, conversation, education
      CONTEXT     131072
    }
    qwen_coder: huggingface "Qwen/Qwen2.5-Coder-7B-Instruct" {
      STRENGTHS   coding
      CONTEXT     32768
    }
  }

  TIER 2 mid {
    haiku: anthropic "claude-haiku-4-5-20251001" {
      STRENGTHS   coding, analysis
      COST        0.1
      CONTEXT     200000
    }
    gpt4mini: openai "gpt-4o-mini" {
      STRENGTHS   general, coding, creative_writing
      COST        0.015
      CONTEXT     128000
    }
  }

  TIER 3 premium {
    sonnet: anthropic "claude-sonnet-4-20250514" {
      STRENGTHS   coding, analysis, creative_writing
      COST        0.3
      CONTEXT     200000
    }
    opus: anthropic "claude-opus-4-6" {
      STRENGTHS   coding, analysis, research
      COST        1.5
      CONTEXT     200000
    }
  }

  TASK_TYPES    coding, creative_writing, analysis, math, conversation, research, education, general
  MOSH_PIT      3
  CALIBRATION   true
}

// ===================================================================
// SKILL DOCUMENTS — Domain expertise injection
// ===================================================================

SKILL novasyn_dev_stack {
  DESCRIPTION  "NovaSyn development patterns and coding standards"
  KEYWORDS     typescript, react, zustand, tauri, electron, ipc, schema, component, novasyn
  DOMAIN       "coding"
  PRIORITY     10
}

SKILL creative_writing {
  DESCRIPTION  "Author voice matching and narrative techniques"
  KEYWORDS     write, story, novel, chapter, character, plot, voice, narrative
  DOMAIN       "creative_writing"
  PRIORITY     7
}

// ===================================================================
// DATA MODELS — Schema-first, everything flows from here
// ===================================================================

ENTITY User {
  email: string REQUIRED UNIQUE
  name: string
  TIMESTAMPS

  // Default user — every Session/Folder/Tag FK requires a User to exist.
  // INSERT OR IGNORE in the migration makes this idempotent on every boot.
  SEED {
    id: "default-user"
    email: "you@local"
    name: "You"
  }
}

ENTITY Workspace {
  name: string REQUIRED
  db_path: string REQUIRED
  is_active: bool = false
  BELONGS_TO User
  TIMESTAMPS
}

ENTITY Session {
  name: string REQUIRED
  BELONGS_TO User
  TIMESTAMPS
}

ENTITY Folder {
  name: string REQUIRED
  description: string
  parent_id: string
  total_tokens: number = 0
  BELONGS_TO User
  TIMESTAMPS
}

ENTITY FolderItem {
  content: string REQUIRED
  tokens: number REQUIRED
  item_type: string
  filename: string
  source_type: string
  BELONGS_TO Folder
  TIMESTAMPS
}

ENTITY Tag {
  name: string REQUIRED
  color: string = "#FCD34D"
  usage_count: number = 0
  BELONGS_TO User
  TIMESTAMPS
  CRUD full
}

ENTITY ChatMessage {
  user_message: string REQUIRED
  ai_message: string REQUIRED
  user_tokens: number REQUIRED
  ai_tokens: number REQUIRED
  total_tokens: number REQUIRED
  model: string REQUIRED
  provider: string REQUIRED
  selected_folders: json = []
  selected_tags: json = []
  is_excluded: bool = false
  is_pruned: bool = false
  is_saved: bool = false
  is_archived: bool = false
  exchange_id: string
  system_prompt: string
  context_history_ids: json = []
  alternatives: json
  babyai_request_id: string
  timestamp: datetime
  BELONGS_TO User
  BELONGS_TO Session
  // Chat UIs want oldest → newest top-to-bottom (newest at the bottom).
  // ORDER ASC pushes the sort into SQLite — no client-side .reverse().
  ORDER ASC
  TIMESTAMPS
}

// Junction: ChatMessage <-> Tag (many-to-many)
ENTITY ChatMessageTag {
  BELONGS_TO ChatMessage
  BELONGS_TO Tag
  TIMESTAMPS
}

// Junction: ChatMessage <-> Folder (many-to-many)
ENTITY ChatMessageFolder {
  BELONGS_TO ChatMessage
  BELONGS_TO Folder
  TIMESTAMPS
}

ENTITY Exchange {
  prompt: string REQUIRED
  response: string REQUIRED
  model: string REQUIRED
  provider: string REQUIRED
  rating: number
  success: bool = true
  BELONGS_TO User
  TIMESTAMPS
}

// Junction: Exchange <-> Tag (many-to-many)
ENTITY ExchangeTag {
  BELONGS_TO Exchange
  BELONGS_TO Tag
  TIMESTAMPS
}

ENTITY Document {
  title: string REQUIRED
  file_path: string REQUIRED
  language: string = "markdown"
  TIMESTAMPS
}

// Orchestration system (from migration 009)
ENTITY Orchestration {
  name: string REQUIRED
  description: string
  steps: json = []
  is_template: bool = false
  TIMESTAMPS
}

ENTITY OrchestrationRun {
  status: string = "pending"
  current_step_index: number = 0
  step_results: json = []
  error: string
  started_at: datetime
  paused_at: string
  completed_at: string
  BELONGS_TO Orchestration
  TIMESTAMPS
}

// ===================================================================
// AI ACTIONS — Beyond CRUD
// ===================================================================

ACTION send_chat {
  INPUT   user_message: string, model: string, system_prompt: string, context_folder_ids: json, context_tag_ids: json, history_ids: json
  OUTPUT  response: ChatMessage
  AI      "{{system_prompt}}\n\n{{context}}\n\n{{user_message}}"
  STREAM  true
}

ACTION broadcast_chat {
  INPUT   user_message: string, model_ids: json, system_prompt: string, context_folder_ids: json
  OUTPUT  results: json
  STREAM  false
}

ACTION council_chat {
  INPUT   user_message: string, model_ids: json, system_prompt: string, synthesis_model: string
  OUTPUT  synthesized: ChatMessage
  AI      "You are a council synthesizer. Multiple AI models have responded to the same prompt. Synthesize their responses into a single comprehensive answer that captures the best insights from each."
  STREAM  true
}

ACTION search_chats {
  INPUT   query: string, user_id: string
  OUTPUT  results: json
}

ACTION web_search {
  INPUT   query: string, num_results: number = 5
  OUTPUT  results: json
}

ACTION export_session_md {
  INPUT   session_id: string
  OUTPUT  markdown: string
}

// ===================================================================
// SEMANTIC SESSIONS — Cognitive operating modes
// ===================================================================

SESSION chat {
  DESCRIPTION  "Primary AI conversation interface"
  TOOLS        chat, search, folder_browse, tag_picker, web_search, broadcast, council
  CONTEXT      conversation
  MEMORY       persistent
  OUTPUT       text, exchange
  PERSIST      true
}

SESSION terminal {
  DESCRIPTION  "Command-line workspace with WSL and PowerShell"
  TOOLS        terminal, file_edit
  CONTEXT      minimal
  MEMORY       session
  OUTPUT       code
  PERSIST      false
}

SESSION document {
  DESCRIPTION  "Document viewer and editor"
  TOOLS        editor, chat
  CONTEXT      structured
  MEMORY       persistent
  OUTPUT       text, document
  PERSIST      true
}

// ===================================================================
// SEMANTIC COMPILERS — "Send To" transitions
// ===================================================================

COMPILER chat_to_exchange {
  DESCRIPTION  "Save a valuable chat exchange for reuse"
  FROM         chat
  TO           chat
  EXTRACT      prompt, response, model, rating
  VALIDATE     true
}

COMPILER chat_to_folder {
  DESCRIPTION  "Save chat content into a context folder"
  FROM         chat
  TO           chat
  EXTRACT      content, topic
  ENRICH {
    INFER       topic_classification
    GENERATE    summary
    PRESERVE    original_content
  }
  VALIDATE     false
}

COMPILER chat_to_skilldoc {
  DESCRIPTION  "Extract behavioral specifications from conversation"
  FROM         chat
  TO           document
  EXTRACT      policies, constraints, behaviors, patterns
  ENRICH {
    INFER       implicit_constraints
    SUGGEST     orchestration_patterns
    DETECT      policy_gaps
    PRESERVE    original_intent
  }
  AI           "Analyze this conversation and extract all behavioral specifications, runtime policies, and operational constraints. Output as a structured skill document."
  VALIDATE     true
}

COMPILER chat_to_requirements {
  DESCRIPTION  "Extract implementation requirements from discussion"
  FROM         chat
  TO           document
  EXTRACT      features, entities, workflows, architecture
  ENRICH {
    INFER       missing_dependencies
    SUGGEST     architecture_patterns
    GENERATE    test_scenarios
    DETECT      contradictions
    PRESERVE    original_intent
  }
  AI           "Extract all implementation requirements from this conversation. Output as a structured requirements document."
  VALIDATE     true
}

COMPILER chat_to_post {
  DESCRIPTION  "Transform discussion into a publishable blog post"
  FROM         chat
  TO           document
  EXTRACT      key_points, structure, narrative
  ENRICH {
    SUGGEST     better_structure
    GENERATE    introduction
    GENERATE    conclusion
  }
  AI           "Transform this conversation into a well-structured blog post."
  VALIDATE     false
}

// ===================================================================
// SHARED INFRASTRUCTURE
// ===================================================================

VAULT {
  PATH         "%APPDATA%/NovaSyn/vault.db"
  ASSET_TYPES  text, json, code, prompt_template, skilldoc, exchange
  PROVENANCE   true
  TAGS         true
}

// ===================================================================
// VIEWS — The UI
// ===================================================================

VIEW ChatView {
  LAYOUT   custom
  SIDEBAR  icon: MessageSquare
  TITLE    "Chat"
}

VIEW TerminalView {
  LAYOUT   custom
  SIDEBAR  icon: Terminal
  TITLE    "Terminal"
}

VIEW FolderPanel {
  ENTITY   Folder
  LAYOUT   split
  ACTIONS  create, edit, delete
  SIDEBAR  icon: FolderOpen
  FIELDS   name, total_tokens
}

VIEW TagManager {
  ENTITY   Tag
  LAYOUT   table
  ACTIONS  create, edit, delete
  SIDEBAR  icon: Tags
  FIELDS   name, color, usage_count
}

VIEW ExchangeLibrary {
  ENTITY   Exchange
  LAYOUT   split
  ACTIONS  create, delete
  SIDEBAR  icon: BookMarked
  FIELDS   prompt, model, rating, created_at
}

VIEW DocumentEditor {
  ENTITY   Document
  LAYOUT   document_editor
  SIDEBAR  icon: FileText
  TITLE    "Documents"
}

VIEW SettingsView {
  LAYOUT   settings
  SIDEBAR  icon: Settings
  TITLE    "Settings"
}

// ===================================================================
// QUALITY CONTROL — SPC on AI response quality
// ===================================================================

QC response_quality {
  YOUNG_THRESHOLD     50
  MATURING_THRESHOLD  200
  YOUNG_PASS_RATE     0.85
  MATURE_PASS_RATE    0.95
  MATURING_SAMPLE     0.30
  MATURE_SAMPLE       0.05
}

// ===================================================================
// TESTS
// ===================================================================

TEST user_crud {
  GIVEN User { email: "test@novasyn.ai", name: "Test User" }
  EXPECT create -> id IS NOT NULL
  EXPECT create -> email == "test@novasyn.ai"
}

TEST session_crud {
  GIVEN User { email: "test@novasyn.ai" }
  GIVEN Session { name: "Test Session", BELONGS_TO User }
  EXPECT create -> id IS NOT NULL
  EXPECT create -> name == "Test Session"
}

TEST folder_hierarchy {
  GIVEN User { email: "test@novasyn.ai" }
  GIVEN Folder { name: "Root Folder", BELONGS_TO User }
  GIVEN FolderItem { content: "Test content", tokens: 50, BELONGS_TO Folder }
  EXPECT create -> id IS NOT NULL
  EXPECT create -> tokens == 50
}

TEST chat_message_flow {
  GIVEN User { email: "test@novasyn.ai" }
  GIVEN Session { name: "Chat Session", BELONGS_TO User }
  GIVEN ChatMessage { user_message: "Hello", ai_message: "Hi there", user_tokens: 5, ai_tokens: 10, total_tokens: 15, model: "claude-sonnet-4-20250514", provider: "anthropic", BELONGS_TO User, BELONGS_TO Session }
  EXPECT create -> id IS NOT NULL
  EXPECT create -> total_tokens == 15
  EXPECT create -> is_excluded == false
}

TEST tag_system {
  GIVEN User { email: "test@novasyn.ai" }
  GIVEN Tag { name: "Important", color: "#EF4444", BELONGS_TO User }
  EXPECT create -> id IS NOT NULL
  EXPECT create -> color == "#EF4444"
  EXPECT create -> usage_count == 0
}

TEST exchange_saving {
  GIVEN User { email: "test@novasyn.ai" }
  GIVEN Exchange { prompt: "How do I...", response: "You can...", model: "claude-sonnet-4-20250514", provider: "anthropic", BELONGS_TO User }
  EXPECT create -> id IS NOT NULL
  EXPECT create -> success == true
}
