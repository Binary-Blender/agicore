{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NovaSyn Chat",
  "version": "0.1.0",
  "identifier": "com.agicore.novasyn_chat",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NovaSyn Chat",
        "width": 1400,
        "height": 900,
        "decorations": false,
        "center": true,
        "minWidth": 1000,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  }
}