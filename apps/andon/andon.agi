// ============================================================================
// VIEWS — the operator interface
// ============================================================================

VIEW AlertStream {
  ENTITY  Alert
  LAYOUT  list
  ACTIONS none                       // alerts are not manually created
  SIDEBAR icon: Bell
  TITLE   "Live alerts"
  FIELDS  external_id, severity, state, category, received_at
}

VIEW RunbookCatalog {
  ENTITY  Runbook
  LAYOUT  table
  ACTIONS edit                       // tier-gated edits only via mutation system
  SIDEBAR icon: BookOpen
  TITLE   "Runbooks"
  FIELDS  name, category, version, estimated_ttr, is_active
}

VIEW IncidentBoard {
  ENTITY  Incident
  LAYOUT  table
  ACTIONS edit, delete
  SIDEBAR icon: AlertOctagon
  TITLE   "Open incidents"
  FIELDS  severity, state, assigned_to, opened_at
}

VIEW AndonHistory {
  ENTITY  AndonEvent
  LAYOUT  list
  ACTIONS none
  SIDEBAR icon: Activity
  TITLE   "Andon events"
  FIELDS  failure_category, workflow_name, fired_at, resolved_at
}

VIEW MutationLedgerView {
  ENTITY  MutationLedger
  LAYOUT  table
  ACTIONS none
  SIDEBAR icon: GitBranch
  TITLE   "Mutation history"
  FIELDS  proposal_id, applied_at, applied_by, effectiveness_score
}

VIEW EfficiencyProposals {
  ENTITY  EfficiencyProposal
  LAYOUT  list
  ACTIONS edit                       // human can approve / reject T3+
  SIDEBAR icon: TrendingUp
  TITLE   "Efficiency proposals"
  FIELDS  source_metric, baseline_value, target_value, status
}

VIEW ServiceMap {
  ENTITY  Service
  LAYOUT  grid
  ACTIONS create, edit, delete
  SIDEBAR icon: Server
  TITLE   "Services"
  FIELDS  name, criticality, owner_team
}

VIEW OncallRoster {
  ENTITY  OncallEngineer
  LAYOUT  table
  ACTIONS create, edit, delete
  SIDEBAR icon: Users
  TITLE   "On-call"
  FIELDS  name, team, on_call_now, escalation_level
}

VIEW SettingsView {
  LAYOUT  settings
  SIDEBAR icon: Settings
  TITLE   "Settings"
}

