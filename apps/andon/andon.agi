// ============================================================================
// TESTS — verification that the system handles canonical scenarios
// ============================================================================

TEST cpu_alert_classifies_and_dispatches {
  GIVEN Service { id: "svc-web", name: "web-frontend", criticality: "critical", owner_team: "platform" }
  GIVEN Alert {
    external_id: "test-001",
    source: "datadog",
    severity: "warning",
    raw_payload: "{\"metric\":\"cpu_usage\",\"value\":87}",
    BELONGS_TO Service
  }
  EXPECT create -> id IS NOT NULL
  EXPECT update { category: "cpu_pressure" } -> category == "cpu_pressure"
}

TEST disk_full_alert_handled {
  GIVEN Service { id: "svc-db-pri", name: "postgres-primary", criticality: "critical", owner_team: "data" }
  GIVEN Alert {
    external_id: "test-002",
    source: "prometheus",
    severity: "critical",
    raw_payload: "{\"metric\":\"disk_usage\",\"value\":96}",
    BELONGS_TO Service
  }
  EXPECT create -> id IS NOT NULL
  EXPECT update { category: "disk_full" } -> category == "disk_full"
}

TEST deploy_failure_triggers_rollback_runbook {
  GIVEN Service { id: "svc-auth", name: "auth-service", criticality: "critical", owner_team: "identity" }
  GIVEN Alert {
    external_id: "test-003",
    source: "ci_cd",
    severity: "critical",
    raw_payload: "{\"event\":\"deploy_failed\",\"deploy_id\":\"d-12345\"}",
    BELONGS_TO Service
  }
  EXPECT create -> id IS NOT NULL
  EXPECT update { category: "deploy_failure", runbook_id: "rb-deploy" } -> category == "deploy_failure"
}

TEST novel_alert_pulls_andon {
  GIVEN Service { id: "svc-queue", name: "rabbitmq", criticality: "critical", owner_team: "platform" }
  GIVEN Alert {
    external_id: "test-004",
    source: "custom",
    severity: "warning",
    raw_payload: "{\"metric\":\"consumer_lag_growth_rate\",\"value\":\"+12%\"}",
    BELONGS_TO Service
  }
  EXPECT create -> id IS NOT NULL
  EXPECT update { state: "andon" } -> state == "andon"
}
