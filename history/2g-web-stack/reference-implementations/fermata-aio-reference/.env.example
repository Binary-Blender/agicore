# Binary Blender Orchestrator - Environment Configuration Template
# Copy this file to .env and fill in your values

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/orchestrator
# For development with SQLite:
# DATABASE_URL=sqlite:///./orchestrator.db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# MCP Server URLs (Model Context Protocol)
MCP_OPENAI_URL=http://localhost:8080
MCP_DALLE_URL=http://localhost:8081
MCP_ANTHROPIC_URL=http://localhost:8082
MCP_ELEVENLABS_URL=http://localhost:8083

# External AI Service API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
ELEVENLABS_API_KEY=...

# S3/Storage Configuration (for asset storage)
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_S3_BUCKET=orchestrator-assets
AWS_REGION=us-east-1

# Redis (optional, for caching and queuing)
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# SPC Configuration
SPC_INITIAL_SAMPLING_RATE=1.0
SPC_MATURE_THRESHOLD_SAMPLES=100
SPC_MATURE_SAMPLING_RATE=0.05
SPC_PASS_RATE_THRESHOLD=0.95
